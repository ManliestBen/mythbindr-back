# MythBindr — server environment
# Copy this file to `.env` and fill in the values. `.env` is gitignored.

# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# Origin of the Vite client (used for CORS + WebAuthn). No trailing slash.
CLIENT_ORIGIN=http://localhost:5173

# ── Database ────────────────────────────────────────────
# MongoDB connection string (Atlas or local).
# Example: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/mythbindr?retryWrites=true&w=majority
MONGODB_URI=

# ── Sessions ────────────────────────────────────────────
# Secret used to sign session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=

# ── Passkeys / WebAuthn (SimpleWebAuthn) ────────────────
# Relying Party ID = the site's registrable domain, NO scheme or port.
# Use "localhost" in development.
RP_ID=localhost
# Human-readable name shown in the OS passkey prompt.
RP_NAME=MythBindr
# Full origin the browser sees, including scheme + port. Must match the client.
RP_ORIGIN=http://localhost:5173

# ── Spotify integration (OAuth 2.0) — see docs/spotify-setup.md ─────────
# From the Spotify Developer Dashboard (https://developer.spotify.com/dashboard).
# NOT a single API key: you get a Client ID + Client Secret. Secret stays server-side.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Must byte-for-byte match a Redirect URI registered in the dashboard.
# Use 127.0.0.1 (not localhost) for local dev — Spotify rejects localhost.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:4000/api/integrations/spotify/callback

# ── Production notes (set these at deploy; see docs/deploy/) ─────────────
# Self-hosted on a Raspberry Pi: SPA + API are served SAME-ORIGIN from your own
# domain via Caddy + Cloudflare Tunnel (docs/deploy/cloudflare-caddy.md).
# Example production values (app served on its own subdomain):
#   NODE_ENV=production
#   CLIENT_ORIGIN=https://mythbindr.benmanley.biz
#   RP_ID=mythbindr.benmanley.biz        # this exact host, no scheme/port
#   RP_NAME=MythBindr
#   RP_ORIGIN=https://mythbindr.benmanley.biz
# Same-origin means session cookies stay SameSite=Lax; Secure (no SameSite=None
# needed). CORS still uses credentials with CLIENT_ORIGIN as the allowed origin.
